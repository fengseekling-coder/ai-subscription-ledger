{
  "name": "ai-subscription-ledger",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run tauri:dev -w @ai-sub/desktop",
    "build": "npm run build -w @ai-sub/core && npm run build -w @ai-sub/desktop",
    "test:core": "npm run test -w @ai-sub/core",
    "parity": "npm run build -w @ai-sub/core && node scripts/parity-html-core.mjs",
    "check": "npm run test:core && npm run parity && npm run build",
    "lint": "eslint packages/core/src apps/desktop/src --max-warnings 0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.2",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "zustand": "5.0.14"
  }
}
